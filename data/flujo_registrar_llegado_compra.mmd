---
title: Caso de Uso 3 — Registrar Llegada de PO a Bodega
---
flowchart TD
    A([Inicio]) --> B["Selecciona una orden<br/>en estado <b>Por llegar</b>"]
    B --> C[/"Muestra resumen<br/>de la orden"/]
    C --> D{"¿Confirma la<br/>llegada a bodega?"}
    D -- No --> Z([Fin])
    D -- Sí --> E["Actualiza el estado de<br/>la orden a <b>En bodega</b>"]
    E --> F["Registra el cambio en el historial<br/>— Fecha y hora de llegada<br/>— Usuario que confirmó"]
    F --> G[/"Muestra confirmación<br/>del registro"/]
    G --> Z

    classDef success fill:#065f46,stroke:#10b981,color:#d1fae5
    classDef usuario fill:#1e1b4b,stroke:#6c63ff,color:#e0e7ff
    classDef sistema fill:#2e1065,stroke:#7c3aed,color:#ede9fe
    classDef terminal fill:#0f0f1a,stroke:#4a4a8a,color:#ffffff

    class B,D usuario
    class C,E sistema
    class F,G success
    class A,Z terminal
