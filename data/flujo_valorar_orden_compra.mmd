---
title: Caso de Uso 6 — Valorar Orden de Compra
---
flowchart TD
    A([Inicio]) --> B["Recibe correo con link<br/>para realizar la valoración"]
    B --> C["Accede al link de valoración"]
    C --> D{"¿La orden ya tiene<br/>una valoración registrada?"}

    D -- No --> E[/"Muestra formulario de valoración vacío"/]
    D -- Sí, corrección --> F["<b>[Flujo alt.]</b> Modo corrección<br/>Muestra el código de valoración actual<br/>para que pueda ser corregido"]

    E --> G["Ingresa o corrige el<br/>código de valoración"]
    F --> G
    G --> H{"¿Confirma la valoración?"}

    H -- No --> I["Cancela sin realizar cambios"]
    I --> Z1([Fin])

    H -- Sí --> J["Registra el código de<br/>valoración en la orden"]
    J --> K["Actualiza el estado de la orden<br/>a <b>Valorada</b>"]
    K --> L["Registra el cambio en el historial<br/>— Fecha y hora de la valoración<br/>— Código de valoración ingresado"]
    L --> M["Envía notificación por correo<br/>a los usuarios relacionados"]
    M --> N[/"Muestra confirmación de éxito<br/>— Código de la orden<br/>— Código de valoración registrado"/]
    N --> O[/"Mantiene el link activo<br/>para futuras correcciones"/]
    O -. Si necesita corregir .-> C
    O --> Z2([Fin])

    classDef usuario fill:#1e1b4b,stroke:#6c63ff,color:#e0e7ff
    classDef sistema fill:#2e1065,stroke:#7c3aed,color:#ede9fe
    classDef alt fill:#422006,stroke:#d97706,color:#fde68a
    classDef success fill:#065f46,stroke:#10b981,color:#d1fae5
    classDef terminal fill:#0f0f1a,stroke:#4a4a8a,color:#ffffff

    class B,C,G,H,I usuario
    class D,E,F,J,O sistema
    class F alt
    class K,L,M,N success
    class A,Z1,Z2 terminal